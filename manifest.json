{
  "manifest_version": 3,
  "name": "Steam Heatmap Tracker",
  "version": "1.0.0",
  "description": "Track cursor dwell & scroll stops on Steam, then overlay a heatmap to see where you paused.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://store.steampowered.com/*",
    "https://*.steampowered.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://store.steampowered.com/*",
        "https://*.steampowered.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
